{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "pnpm build",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": ".next",
  "regions": ["fra1"],
  "crons": [
    { "path": "/api/cron/evolution-health", "schedule": "*/10 * * * *" },
    { "path": "/api/cron/onboarding-reap", "schedule": "* * * * *" },
    { "path": "/api/cron/onboarding-purge", "schedule": "0 3 * * *" },
    { "path": "/api/cron/commissions-mature", "schedule": "0 3 * * *" },
    { "path": "/api/cron/closed-days-cleanup", "schedule": "0 3 * * *" },
    { "path": "/api/cron/resellers-payout-run", "schedule": "0 8 5 * *" },
    { "path": "/api/cron/verifactu-retry", "schedule": "0 * * * *" },
    { "path": "/api/cron/learning", "schedule": "0 3 * * *" },
    { "path": "/api/cron/sessions-cleanup", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/daily-sales-report", "schedule": "55 22 * * *" },
    { "path": "/api/cron/appointments-reminder", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/post-order-surveys", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/validator-regression", "schedule": "0 6 * * *" },
    { "path": "/api/cron/auto-open-shifts", "schedule": "*/5 * * * *" }
  ],
  "headers": [
    {
      "source": "/((?!chat/).*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/chat/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
      ]
    }
  ]
}
