# ═══════════════════════════════════════════════════════════
# Ordy Chat — Variables de entorno
# Copia este archivo como .env y completa los valores.
# NUNCA subas .env a GitHub.
# ═══════════════════════════════════════════════════════════

# ── Base de datos (Neon Postgres) ──────────────────────────
DATABASE_URL=postgresql://neondb_owner:PASS@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# ── Auth.js ────────────────────────────────────────────────
# Genera con: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Magic-link email (Resend recomendado)
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM=noreply@ordychat.com

# ── Anthropic (fallback global, cada tenant puede traer la suya) ──
ANTHROPIC_API_KEY=

# ── Stripe (€19.90/mes) ────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# ── Cifrado de credenciales de tenants ─────────────────────
# AES-256-GCM, 32 bytes en base64. Genera con:
# node -e "console.log(crypto.randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# ── Runtime Python (FastAPI) ───────────────────────────────
RUNTIME_URL=http://localhost:8000
RUNTIME_INTERNAL_SECRET=

# ── Super admin inicial ────────────────────────────────────
# Email que obtiene role='super_admin' al registrarse
SUPER_ADMIN_EMAIL=mtmbdeals@gmail.com

# ── Público ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
